# Docker image to pull (override if self-hosting under a different name)
SYNCCIT_IMAGE=ghcr.io/thinkaliker/synccit:latest

# Port to expose on the host
APP_PORT=8080

# ── Database ────────────────────────────────────────────────────────────────
# For bundled DB (--profile internal-db), these are used for both the MySQL
# container and the app. For an external DB, point DB_HOST at your server.
DB_HOST=db
DB_USER=synccit
DB_PASS=synccit
DB_NAME=rddtsync

# Root password only used by the bundled MySQL container
MYSQL_ROOT_PASSWORD=changeme

# ── Application ─────────────────────────────────────────────────────────────
# Public-facing host, no trailing slash
BASE_HOST=http://localhost:8080

# Subpath if not serving from /  (e.g. /synccit). Leave blank for root.
BASE_URL=

# Override API location if different from BASE_HOST/api/
API_LOC=

# Enable mod_rewrite pretty URLs (true/false)
PRETTY_URLS=true

# Set to true to also initialize the optional apps table on first start
INIT_APPS_DB=false

# ── SMTP (for password reset emails) ────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_ENC=ssl
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
